# Frontend environment variables (Vite)
# Copy this file to .env and fill in the values

# Google reCAPTCHA v3 — PUBLIC site key (safe to expose in frontend)
# Get from: https://www.google.com/recaptcha/admin/create
# Choose "reCAPTCHA v3", add your domain
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
RECAPTCHA_ENFORCE=true # true to enforce reCAPTCHA on all forms, false to disable